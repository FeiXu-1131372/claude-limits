{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissions for the popover and report windows",
  "windows": [
    "popover",
    "report"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-set-position",
    "core:window:allow-hide",
    "opener:default",
    "autostart:default",
    "dialog:default",
    "notification:default",
    "os:default",
    "shell:default",
    "window-state:default"
  ]
}
